# Core
NODE_ENV=production

# App region and DynamoDB
APP_REGION=ap-south-1
# APP_DEFAULT_REGION=ap-south-1
AUTO_CREATE_DYNAMO_TABLES=false
DDB_INQUIRIES_TABLE_NAME=treataxis-inquiries-prod
DDB_CHAT_TABLE_NAME=treataxis-chat-prod

# Perplexity
PERPLEXITY_API_KEY=
PERPLEXITY_MODEL=sonar

# Lead delivery integrations (optional as per your stack)
RESEND_API_KEY=
LEAD_EMAIL_FROM=
LEAD_EMAIL_TO=
HUBSPOT_PRIVATE_APP_TOKEN=
LEAD_WEBHOOK_URL=
WHATSAPP_WEBHOOK_URL=
GOOGLE_SHEETS_WEBHOOK_URL=
CRM_WEBHOOK_URL=
